(define
    (problem prob_safe_vs_risky_n03_r01)
    (:domain prob_safe_vs_risky)
    (:objects
        s0 s1 s2 - step
        s0r0 s1r0 s2r0 - rtoken
    )
    (:htn
        :parameters ()
        :subtasks (and
            (t0 (do_phase s0 s0r0))
            (t1 (do_phase s1 s1r0))
            (t2 (do_phase s2 s2r0))
        )
        :ordering (and
            (< t0 t1)
            (< t1 t2)
        )
    )
    (:init)
)
