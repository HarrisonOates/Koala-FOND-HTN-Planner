(define
    (problem prob_safe_vs_risky_n02_r02)
    (:domain prob_safe_vs_risky)
    (:objects
        s0 s1 - step
        s0r0 s0r1 s1r0 s1r1 - rtoken
    )
    (:htn
        :parameters ()
        :subtasks (and
            (t0 (do_phase s0 s0r0))
            (t1 (do_phase s1 s1r0))
        )
        :ordering (and
            (< t0 t1)
        )
    )
    (:init
        (next_rtoken s0r0 s0r1)
        (next_rtoken s1r0 s1r1)
    )
)
