(define
    (problem lunch_1)
    (:domain fail_lunch)
    (:objects
        door_0 - door
    )
    (:htn
        :parameters ()
        :subtasks (and
            (task0 (inspect_door door_0))
            (task1 (eat_lunch))
            (task2 (final_check))
        )
        :ordering (and
            (< task0 task1)
            (< task1 task2)
        )
    )
    (:init)
)
