(define (domain jani_from_ppddl)
	(:requirements :typing :hierarchy)
	(:types bool loc int num)
	(:constants
		goal_condition - bool
		var0 - int
		var1 - int
		var2 - int
		var3 - int
		var4 - int
		var5 - int
		var6 - int
		var7 - int
		var8 - int
		var9 - int
		var10 - int
		loc0_aut - loc
		n0 n1 n2 n3 n4 n5 n6 n7 - num
	)
	(:predicates
		(fulfiled ?x - bool)
		(at ?l - loc)
		(value ?v - int ?n - num)
	)

	;; HTN task
	(:task solve :parameters ())
	(:method m_solve_done
		:parameters ()
		:task (solve)
		:precondition (fulfiled goal_condition)
		:subtasks ()
	)

